fun foo xs {
    x := (head xs);
    y := (head (tail xs));
    x := (x + 1);
    x := (x + 2);
    x := (x + 3);
    if (x < 10) then {
        y := (y + 0);
        y := (y + 1);
        y := (y + 2);
        y := (y + 3);
        y := (y + 4);
        y := (y + 5);
        y := (y + 6);
        y := (y + 7);
        y := (y + 8);
        y := (y + 9);
    } else {
        x := (x + 0);
        x := (x + 1);
        x := (x + 2);
        x := (x + 3);
        x := (x + 4);
        x := (x + 5);
        x := (x + 6);
        x := (x + 7);
        x := (x + 8);
        x := (x + 9);
    };
} (Cons x (Cons y xs));

