fun foo xs {
  res := Nil;
  r := (3+3/4-3+1)*10%3+2 == 3 && (False || (False || 2 < 3 ));
  if r then {res := Cons 0 Nil} else {res := Cons 1 Nil}
} res;

fun bar xs {
    x := 0;
    y := 0;
    if True then {
      x := x + 1;
    } else {
      y := y + 1; 
    };
    if !False then {
      x := x + 1;
    } else {
      y := y + 1; 
    };
    if (3 + 3/4 - 3 + 1) * 10 % 3 + 2 == 3 && (False || (False || 2 < 3)) then {
      x := x + 1;
    } else {
      y := y + 1; 
    }
} Cons x (Cons y Nil);